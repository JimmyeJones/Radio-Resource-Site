{
  "name": "radio-resource-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "worker": "tsx src/worker/index.ts",
    "worker:prod": "node dist/worker/index.js",
    "build:worker": "tsc -p tsconfig.worker.json && tsc-alias -p tsconfig.worker.json"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "better-sqlite3": "^11.3.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.1.6",
    "drizzle-orm": "^0.36.0",
    "jsdom": "^25.0.1",
    "lucide-react": "^0.454.0",
    "next": "14.2.18",
    "node-cron": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "satellite.js": "^5.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.18",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
